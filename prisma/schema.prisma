generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users & Auth ────────────────────────────────────────────────────────────

model User {
  id               String   @id @default(cuid())
  name             String?
  email            String   @unique
  emailVerified    DateTime?
  image            String?
  plan             Plan     @default(FREE)
  stripeCustomerId String?  @unique
  timezone         String   @default("UTC")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  accounts       Account[]
  sessions       Session[]
  socialAccounts SocialAccount[]
  posts          Post[]
  aiUsages       AiUsage[]
  teamMemberships TeamMember[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Platform Connections ────────────────────────────────────────────────────

model SocialAccount {
  id              String   @id @default(cuid())
  userId          String
  platform        SocialPlatform
  platformUserId  String
  username        String
  displayName     String?
  profileUrl      String?
  avatarUrl       String?
  accessToken     String   @db.Text  // encrypted at rest
  refreshToken    String?  @db.Text  // encrypted at rest
  tokenExpiresAt  DateTime?
  scopes          String?
  metadata        Json?    // platform-specific data (karma, etc.)
  connectedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  postTargets PostTarget[]

  @@unique([userId, platform, platformUserId])
  @@index([userId])
}

// ─── Posts ────────────────────────────────────────────────────────────────────

model Post {
  id           String     @id @default(cuid())
  userId       String
  title        String?
  content      String?    @db.Text
  mediaUrls    String[]
  link         String?
  status       PostStatus @default(DRAFT)
  scheduledAt  DateTime?
  publishedAt  DateTime?
  errorMessage String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  targets PostTarget[]

  @@index([userId, status])
  @@index([scheduledAt])
}

model PostTarget {
  id              String     @id @default(cuid())
  postId          String
  socialAccountId String
  platform        SocialPlatform
  subreddit       String?
  flair           String?
  platformPostId  String?    // ID on the remote platform after publishing
  publishedUrl    String?
  status          PostStatus @default(DRAFT)
  errorMessage    String?
  retryCount      Int        @default(0)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  post          Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  socialAccount SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  metrics       PostMetric[]

  @@index([postId])
  @@index([socialAccountId])
  @@index([status])
}

// ─── Metrics ─────────────────────────────────────────────────────────────────

model PostMetric {
  id           String   @id @default(cuid())
  postTargetId String
  fetchedAt    DateTime @default(now())
  impressions  Int      @default(0)
  likes        Int      @default(0)
  comments     Int      @default(0)
  shares       Int      @default(0)
  saves        Int      @default(0)
  clicks       Int      @default(0)
  reach        Int      @default(0)
  raw          Json?    // full API response for platform-specific fields

  postTarget PostTarget @relation(fields: [postTargetId], references: [id], onDelete: Cascade)

  @@index([postTargetId, fetchedAt])
}

// ─── Reddit Rule Cache ───────────────────────────────────────────────────────

model SubredditRulesCache {
  id         String   @id @default(cuid())
  subreddit  String   @unique
  rulesJson  Json
  sidebarMd  String?  @db.Text
  wikiJson   Json?
  cachedAt   DateTime @default(now())
  expiresAt  DateTime

  @@index([subreddit])
  @@index([expiresAt])
}

// ─── AI Usage Tracking ───────────────────────────────────────────────────────

model AiUsage {
  id         String   @id @default(cuid())
  userId     String
  feature    AiFeature
  tokensIn   Int      @default(0)
  tokensOut  Int      @default(0)
  model      String   @default("claude-sonnet-4-20250514")
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, feature, createdAt])
}

// ─── Teams (Premium) ─────────────────────────────────────────────────────────

model Team {
  id        String       @id @default(cuid())
  name      String
  ownerId   String
  createdAt DateTime     @default(now())
  members   TeamMember[]
}

model TeamMember {
  id     String   @id @default(cuid())
  teamId String
  userId String
  role   TeamRole @default(MEMBER)
  joinedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Plan {
  FREE
  PREMIUM
}

enum SocialPlatform {
  REDDIT
  TWITTER
  INSTAGRAM
  LINKEDIN
  TIKTOK
  FACEBOOK
  PINTEREST
  MASTODON
  BLUESKY
  YOUTUBE
}

enum PostStatus {
  DRAFT
  SCHEDULED
  POSTING
  PUBLISHED
  FAILED
}

enum AiFeature {
  CAPTION
  HASHTAG
  REDDIT_RULES
  INSIGHT
  REPURPOSE
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
}
