# ═══════════════════════════════════════════════════════════════
# SocialHub — Environment Variables
# Copy this to .env.local and fill in your values
# ═══════════════════════════════════════════════════════════════

# ─── App ──────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=           # openssl rand -base64 32
NEXT_PUBLIC_APP_URL=http://localhost:3000  # Used by manifest, OG images, sitemap

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/socialhub

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Encryption (for token storage) ──────────────────────────
ENCRYPTION_SECRET=         # openssl rand -base64 32

# ─── Reddit OAuth2 ───────────────────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ─── Twitter / X OAuth2 ──────────────────────────────────────
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# ─── Instagram (Meta) OAuth2 ─────────────────────────────────
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# ─── LinkedIn OAuth2 ─────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ─── Anthropic (Claude AI) ───────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Stripe ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=      # price_xxxxxxxxx (create in Stripe dashboard)
STRIPE_PRICE_YEARLY=        # price_xxxxxxxxx

# ─── Resend (email notifications) ────────────────────────────
RESEND_API_KEY=

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=info              # debug | info | warn | error
